---
layout: null
---
{
  "weekly": [
    {% assign weekly_files = site.static_files | where_exp: "file", "file.path contains '/art/weekly/'" | sort: "path" | reverse %}
    {% for file in weekly_files %}
    {
      "path": {{ file.path | relative_url | jsonify }},
      "name": {{ file.name | jsonify }},
      "modified": {{ file.modified_time | date_to_xmlschema | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ],
  "gallery": [
    {% assign gallery_files = site.static_files | where_exp: "file", "file.path contains '/art/gallery/'" | sort: "path" | reverse %}
    {% for file in gallery_files %}
    {
      "path": {{ file.path | relative_url | jsonify }},
      "name": {{ file.name | jsonify }},
      "modified": {{ file.modified_time | date_to_xmlschema | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
